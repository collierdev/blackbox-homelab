# Pi Dashboard Environment Variables

# Server
NODE_ENV=production
PORT=80

# Neo4J Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=dashboard123

# Google Calendar API
# Get credentials from: https://console.cloud.google.com
# 1. Create project "Pi Dashboard"
# 2. Enable Google Calendar API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add redirect URI: http://192.168.50.39/api/sync/google/callback
GOOGLE_CLIENT_ID=your_client_id_here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret_here

# Microsoft Outlook / Graph API
# Get credentials from: https://portal.azure.com
# 1. Register app in Azure AD
# 2. Add Calendar.ReadWrite permissions
# 3. Create client secret
MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here
MICROSOFT_TENANT_ID=common

# Apple iCloud CalDAV
# Get app-specific password from: https://appleid.apple.com
# Account > Security > App-Specific Passwords
CALDAV_URL=https://caldav.icloud.com
CALDAV_USERNAME=your_icloud_email@icloud.com
CALDAV_PASSWORD=your_app_specific_password_here

# Encryption Secret (for OAuth tokens)
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=CHANGEME_generate_32_char_random_string

# Ollama (AI - already installed)
OLLAMA_URL=http://localhost:11434

# Home Assistant (existing)
HA_URL=http://192.168.50.39:8123
HA_TOKEN=your_ha_token_here

# Todo.md File Sync Paths (comma-separated)
TODO_MD_PATHS=/home/jwcollie/TODO.md,/home/jwcollie/Dashboard/TODO.md

# go2rtc (existing)
GO2RTC_URL=http://192.168.50.39:1984
