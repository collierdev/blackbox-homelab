# Copy this file to `.env` before first run:
# cp .env.example .env

# Server
NODE_ENV=production
PORT=8080
FRONTEND_URL=http://localhost:8080

# Host path mounts used by dashboard container
HOST_HOME_PATH=/home/jwcollie
HOST_MNT_PATH=/mnt

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=change_me

# go2rtc
GO2RTC_URL=http://localhost:1984
GO2RTC_PUBLIC_URL=http://localhost:1984

# OAuth encryption key for stored tokens/config
# Generate with: openssl rand -base64 32
ENCRYPTION_SECRET=change_me_generate_random_32_plus_chars

# Optional OAuth env fallback (UI setup is preferred)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/sync/google/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8080/api/sync/microsoft/callback

# Optional integrations
OLLAMA_URL=http://localhost:11434
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=
TODO_MD_PATHS=/home/jwcollie/TODO.md,/home/jwcollie/Dashboard/TODO.md
